# ── Substack session cookie ──────────────────────────────────────
# Copy the `substack.sid` cookie from your browser DevTools (see README).
# Used read-only, with YOUR own logged-in session, to read YOUR Notes feed.
SUBSTACK_SESSION_COOKIE=your_substack_sid_here

# ── LLM backend (pick one) ───────────────────────────────────────
# The scorer talks to any OpenAI-compatible endpoint. Choose where it runs:
#
# 1) LM Studio (fully local, private — nothing leaves your machine) [default]
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=
LLM_API_KEY=
#
# 2) Ollama (local):
#    LLM_BASE_URL=http://localhost:11434/v1
#    LLM_MODEL=llama3.1
#    LLM_API_KEY=ollama
#
# 3) OpenAI:
#    LLM_BASE_URL=https://api.openai.com/v1
#    LLM_MODEL=gpt-4o-mini
#    LLM_API_KEY=sk-...
#
# 4) Claude (Anthropic's OpenAI-compatible endpoint):
#    LLM_BASE_URL=https://api.anthropic.com/v1
#    LLM_MODEL=claude-sonnet-4-6
#    LLM_API_KEY=sk-ant-...
#
# 5) OpenRouter (Claude, Llama, many models):
#    LLM_BASE_URL=https://openrouter.ai/api/v1
#    LLM_MODEL=anthropic/claude-sonnet-4-6
#    LLM_API_KEY=sk-or-...
#
# Note: options 3–5 send note content (incl. other people's public notes) to
# that provider. Option 1–2 keep everything on your machine.
